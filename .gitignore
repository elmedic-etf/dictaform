# --- Secrets ----------------------------------------------------------------
# Never commit the OpenRouter API key file.
.env
.env.local
.env.*.local

# --- Local runtime data -----------------------------------------------------
# Logs accumulate sensitive transcript text and should stay on the local box.
logs/

# Session JSON saved on Stop — may contain real PHI; never commit.
output/

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- IDE / editor -----------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# Claude Code per-user local settings (the shared settings.json variant, if
# any, is intentionally not ignored).
.claude/settings.local.json

# --- macOS ------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
